# samslide 환경 변수 예시.
# 각 앱 루트에 .env.local (web-host, web-participant) 또는 .env (api) 로 복사해 사용.
# 실제 .env* 파일은 git에 올라가지 않습니다 (.gitignore 참조).

# ===== apps/api =====
PORT=3001
# 쉼표 구분. 프론트 앱이 추가되면 여기에 오리진을 늘립니다.
CORS_ORIGINS=http://localhost:3000,http://localhost:3002
# 앱 버전 (배포 파이프라인에서 주입 예정)
APP_VERSION=0.0.0-dev

# ===== apps/web-host / apps/web-participant =====
# 브라우저에서 접근 가능한 API 주소. 반드시 NEXT_PUBLIC_ 접두사 필요.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
